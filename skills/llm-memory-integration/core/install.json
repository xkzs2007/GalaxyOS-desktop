{
  "name": "llm-memory-integration",
  "version": "3.2.0",
  "description": "LLM Memory Integration - 私有增强包",
  "author": "xkzs2007",
  "license": "MIT",
  "filesystem": {
    "read": [
      "${OPENCLAW_HOME}/workspace/memory/persona.md",
      "${OPENCLAW_HOME}/workspace/MEMORY.md",
      "${OPENCLAW_HOME}/workspace/SESSION-STATE.md",
      "${OPENCLAW_HOME}/workspace/memory/ontology/graph.jsonl",
      "${OPENCLAW_HOME}/workspace/skills/llm-memory-integration/config/llm_config.json",
      "${OPENCLAW_HOME}/memory-tdai/vectors.db",
      "${OPENCLAW_HOME}/memory-tdai/config/extension_config.json",
      "${OPENCLAW_HOME}/memory-tdai/.cache/",
      "${OPENCLAW_HOME}/memory-tdai/history/",
      "${OPENCLAW_HOME}/memory-tdai/feedback/",
      "${OPENCLAW_HOME}/memory-tdai/extensions/",
      "${OPENCLAW_HOME}/qdrant-storage/",
      "${OPENCLAW_HOME}/tfidf-storage/",
      "${OPENCLAW_HOME}/openclaw.json"
    ],
    "write": [
      "${OPENCLAW_HOME}/workspace/memory/persona.md",
      "${OPENCLAW_HOME}/workspace/MEMORY.md",
      "${OPENCLAW_HOME}/workspace/memory/model_performance.json",
      "${OPENCLAW_HOME}/workspace/memory/ontology/graph.jsonl",
      "${OPENCLAW_HOME}/workspace/brain/",
      "${OPENCLAW_HOME}/memory-tdai/.cache/",
      "${OPENCLAW_HOME}/memory-tdai/history/",
      "${OPENCLAW_HOME}/memory-tdai/feedback/"
    ],
    "description": "通过 OPENCLAW_HOME 环境变量配置根路径（默认 ~/.openclaw）。写入操作受 LLM_MEMORY_ALLOW_PERSONA_WRITE 环境变量控制，默认禁用。"
  },
  "environment_variables": {
    "OPENCLAW_HOME": "OpenClaw 根目录（默认 ~/.openclaw）",
    "OPENCLAW_WORKSPACE": "工作空间目录（默认 ${OPENCLAW_HOME}/workspace）",
    "OPENCLAW_VECTORS_DB": "向量数据库路径（默认 ${OPENCLAW_HOME}/memory-tdai/vectors.db）",
    "OPENCLAW_LLM_CONFIG": "LLM 配置文件路径",
    "LLM_MEMORY_ALLOW_PERSONA_WRITE": "设置为 1 时允许写入 persona.md 和 MEMORY.md（默认禁用）",
    "LLM_BASE_URL": "LLM API 基础 URL",
    "LLM_API_KEY": "LLM API 密钥",
    "LLM_MODEL": "LLM 模型名称"
  },
  "safety": {
    "persona_write_default": false,
    "auto_update_default": false,
    "require_confirmation": true,
    "backup_before_update": true
  }
}