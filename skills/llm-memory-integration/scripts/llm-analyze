#!/usr/bin/env python3
"""llm-analyze - LLM 记忆分析包装脚本"""

import sys
import os
import json
from pathlib import Path

# 添加脚本目录到路径
script_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, script_dir)

# 配置路径
CONFIG_PATH = Path.home() / ".openclaw" / "workspace" / "skills" / "llm-memory-integration" / "config" / "llm_config.json"

def load_config():
    """加载配置"""
    config = {}
    if CONFIG_PATH.exists():
        try:
            with open(CONFIG_PATH) as f:
                cfg = json.load(f)
            llm = cfg.get("llm", {})
            config["llm_url"] = llm.get("base_url", os.environ.get("LLM_BASE_URL", ""))
            config["llm_key"] = llm.get("api_key", os.environ.get("LLM_API_KEY", ""))
            config["llm_model"] = llm.get("model", "gpt-4")
        except:
            pass
    return config

def analyze_persona(content: str) -> str:
    """提取用户偏好"""
    from core import LLMEngine
    
    config = load_config()
    if not config.get("llm_key") or config["llm_key"].startswith("YOUR_"):
        return "⚠️ 请先配置 LLM API 密钥"
    
    llm = LLMEngine(
        api_url=config["llm_url"],
        api_key=config["llm_key"],
        model=config["llm_model"]
    )
    
    prompt = f"""分析以下对话内容，提取用户偏好和特征：

{content}

请以简洁的要点列表形式输出：
1. 用户偏好
2. 行为特征
3. 技术背景"""
    
    return llm.call(prompt, max_tokens=300)

def analyze_scene(content: str) -> str:
    """提取场景"""
    from core import LLMEngine
    
    config = load_config()
    if not config.get("llm_key") or config["llm_key"].startswith("YOUR_"):
        return "⚠️ 请先配置 LLM API 密钥"
    
    llm = LLMEngine(
        api_url=config["llm_url"],
        api_key=config["llm_key"],
        model=config["llm_model"]
    )
    
    prompt = f"""分析以下对话内容，提取关键场景：

{content}

请以简洁的形式输出：
- 场景名称
- 核心事件
- 时间节点"""
    
    return llm.call(prompt, max_tokens=200)

def analyze_summarize(content: str) -> str:
    """总结对话"""
    from core import LLMEngine
    
    config = load_config()
    if not config.get("llm_key") or config["llm_key"].startswith("YOUR_"):
        return "⚠️ 请先配置 LLM API 密钥"
    
    llm = LLMEngine(
        api_url=config["llm_url"],
        api_key=config["llm_key"],
        model=config["llm_model"]
    )
    
    prompt = f"""总结以下对话内容：

{content}

请以简洁的段落形式输出摘要（不超过 200 字）。"""
    
    return llm.call(prompt, max_tokens=150)

def main():
    """主函数"""
    if len(sys.argv) < 3:
        print("用法: llm-analyze <类型> <内容>")
        print("类型: persona | scene | summarize")
        print("\n示例:")
        print("  llm-analyze persona '用户喜欢简洁的回复'")
        print("  llm-analyze scene '今天完成了记忆系统配置'")
        print("  llm-analyze summarize '长对话内容...'")
        sys.exit(1)
    
    analyze_type = sys.argv[1]
    content = sys.argv[2]
    
    if analyze_type == "persona":
        result = analyze_persona(content)
    elif analyze_type == "scene":
        result = analyze_scene(content)
    elif analyze_type == "summarize":
        result = analyze_summarize(content)
    else:
        print(f"❌ 未知分析类型: {analyze_type}")
        print("支持类型: persona | scene | summarize")
        sys.exit(1)
    
    print(result)

if __name__ == "__main__":
    main()
