{
    "id": "galaxyos",
    "name": "GalaxyOS 核心引擎",
    "description": "将 xiaoyi-claw-omega-final 的 13 层架构（防幻觉、知识图谱、CRAG、投机解码等 144 个模块）注册为 OpenClaw 插件，提供增强记忆检索、防幻觉验证、系统健康检测、R-CCAM 认知循环等能力。支持常驻 Python Worker 进程（零进程开销，硬件加速预热）。v8 新增 DAG 上下文管理器（SQLite 持久化 + 摘要回溯），集成到 ContextEngine 的 ingest/compact 流程。",
    "contracts": {
        "contextEngine": {
            "id": "claw-core-engine"
        },
        "tools": [
            "galaxy_pool",
            "claw_rccam_progress",
            "claw_recall",
            "claw_lobster",
            "claw_health",
            "claw_vector_info",
            "claw_events",
            "claw_store",
            "claw_verify",
            "claw_rccam",
            "claw_save_memory",
            "claw_compile_skill",
            "claw_asset_search",
            "claw_asset_register"
        ]
    },
    "configSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
            "autoRecall": {
                "type": "object",
                "description": "对话中自动增强检索",
                "properties": {
                    "enabled": {
                        "type": "boolean",
                        "default": true,
                        "description": "是否启用自动增强记忆检索"
                    }
                }
            },
            "contextEngine": {
                "type": "object",
                "description": "ContextEngine 上下文引擎配置（要求 OpenClaw >= 2026.3.7）",
                "properties": {
                    "maxRecentMessages": {
                        "type": "number",
                        "default": 20,
                        "description": "压缩时保留的最近消息条数"
                    },
                    "recallOnAssemble": {
                        "type": "boolean",
                        "default": true,
                        "description": "assemble 时是否注入增强检索结果"
                    },
                    "dagEnabled": {
                        "type": "boolean",
                        "default": true,
                        "description": "是否启用 DAG 上下文管理器（SQLite 持久化、摘要节点回溯）"
                    },
                    "tokenBudget": {
                        "type": "number",
                        "default": 12000,
                        "description": "ContextEngine assemble 最大 token 预算"
                    },
                    "compactThreshold": {
                        "type": "number",
                        "default": 0.6,
                        "description": "token 使用率触发压缩的阈值（0-1）"
                    },
                    "emergencyCeiling": {
                        "type": "number",
                        "default": 0.88,
                        "description": "紧急裁剪触发阈值（0-1，超过立即裁剪到 safetyMargin）"
                    }
                }
            },
            "memorySlots": {
                "type": "object",
                "description": "记忆槽位配置 — 管理不同层级记忆的容量和策略",
                "properties": {
                    "dag": {
                        "type": "object",
                        "description": "DAG 情景记忆（SQLite 持久化，摘要节点回溯）",
                        "properties": {
                            "enabled": {
                                "type": "boolean",
                                "default": true
                            },
                            "maxNodes": {
                                "type": "number",
                                "default": 10000,
                                "description": "DAG 最大节点数"
                            },
                            "retentionDays": {
                                "type": "number",
                                "default": 90,
                                "description": "DAG 节点保留天数"
                            }
                        }
                    },
                    "verified": {
                        "type": "object",
                        "description": "已验证记忆（verified_memories.jsonl，高置信度持久存储）",
                        "properties": {
                            "enabled": {
                                "type": "boolean",
                                "default": true
                            },
                            "minConfidence": {
                                "type": "number",
                                "default": 0.8,
                                "description": "最低验证置信度阈值"
                            },
                            "maxEntries": {
                                "type": "number",
                                "default": 5000,
                                "description": "最大条目数"
                            }
                        }
                    },
                    "neural": {
                        "type": "object",
                        "description": "神经记忆（MN-RU HNSW 增量索引 + GAT/CfC 检索）",
                        "properties": {
                            "enabled": {
                                "type": "boolean",
                                "default": true
                            },
                            "hnswM": {
                                "type": "number",
                                "default": 16,
                                "description": "HNSW M 参数（连接数）"
                            },
                            "hnswEfConstruction": {
                                "type": "number",
                                "default": 200,
                                "description": "HNSW 构建搜索宽度"
                            },
                            "hnswEfSearch": {
                                "type": "number",
                                "default": 100,
                                "description": "HNSW 检索搜索宽度"
                            }
                        }
                    },
                    "synapse": {
                        "type": "object",
                        "description": "突触网络（GAT/SparseGAT 注意力权重 — LTP/LTD 可塑）",
                        "properties": {
                            "enabled": {
                                "type": "boolean",
                                "default": true
                            },
                            "baseWeight": {
                                "type": "number",
                                "default": 0.5,
                                "description": "新突触初始权重"
                            },
                            "ltpRate": {
                                "type": "number",
                                "default": 0.05,
                                "description": "长时程增强速率"
                            },
                            "ltdRate": {
                                "type": "number",
                                "default": 0.03,
                                "description": "长时程抑制速率"
                            }
                        }
                    },
                    "temporal": {
                        "type": "object",
                        "description": "时序知识图谱（TKG — temporal_kg.db）",
                        "properties": {
                            "enabled": {
                                "type": "boolean",
                                "default": true
                            },
                            "decayHalfLife": {
                                "type": "number",
                                "default": 30,
                                "description": "时间衰减半衰期（天）"
                            }
                        }
                    }
                }
            },
            "tools": {
                "type": "object",
                "description": "工具注册配置",
                "properties": {
                    "enabled": {
                        "type": "boolean",
                        "default": true,
                        "description": "是否注册工具到 agent"
                    }
                }
            },
            "communication": {
                "type": "object",
                "description": "通信通道配置（ZMQ/mmap/UDS），默认值开箱即用，一般无需修改",
                "properties": {
                    "zmqPort": {
                        "type": "number",
                        "default": 5559,
                        "description": "ZMQ PUB 事件推送端口（Worker → Plugin）"
                    },
                    "mmapPath": {
                        "type": "string",
                        "default": "/dev/shm/claw_dag_cache",
                        "description": "mmap 共享内存文件路径（DAG 上下文零拷贝）"
                    }
                }
            },
            "worker": {
                "type": "object",
                "description": "常驻 Python Worker 进程配置",
                "properties": {
                    "enabled": {
                        "type": "boolean",
                        "default": true,
                        "description": "是否启用常驻 Worker 进程（替换 spawnSync，MKL/FMA/io_uring 预热后零进程开销）"
                    }
                }
            }
        }
    },
    "main": "plugin-bootstrap.cjs",
    "mainFallback": [
        "dist/index.js",
        "index.js"
    ],
    "kind": [
        "context-engine",
        "memory"
    ]
}