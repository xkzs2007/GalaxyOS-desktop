{
  "name": "galaxyos-desktop",
  "version": "0.1.0-stage1",
  "description": "GalaxyOS Desktop App — Electron shell + Python sidecar. Decouples GalaxyOS from OpenClaw and runs as a standalone desktop Agent.",
  "main": "dist/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:main": "node esbuild.config.mjs",
    "build:renderer": "node scripts/build-renderer.mjs",
    "build:python": "bash scripts/build-python.sh",
    "build:python:clean": "bash scripts/build-python.sh --clean",
    "build:electron": "electron-builder",
    "build:win": "electron-builder --win nsis --x64",
    "build:mac": "electron-builder --mac dmg --x64",
    "build:mac:arm64": "electron-builder --mac dmg --arm64",
    "build:linux": "electron-builder --linux AppImage --x64",
    "build:all": "npm run build:main && npm run build:python && npm run build:electron",
    "test": "node --test test/*.test.mjs",
    "lint": "node scripts/lint.mjs"
  },
  "dependencies": {
    "@jboltai/tokui": "^0.1.0",
    "zeromq": "^6.0.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "cool.cnb.galaxyos.desktop",
    "productName": "GalaxyOS",
    "copyright": "Copyright © 2026 GalaxyOS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python/dist",
        "to": ".",
        "filter": [
          "galaxyos-sidecar*"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "*.py"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "GalaxyOS"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "executableName": "galaxyos"
    }
  },
  "author": "GalaxyOS Team"
}
