{
  "id": "galaxyos",
  "name": "GalaxyOS 认知增强引擎",
  "description": "将 xiaoyi-claw-omega-final 的 13 层架构（防幻觉、知识图谱、CRAG、投机解码等 144 个模块）注册为 OpenClaw 插件，提供增强记忆检索、防幻觉验证、系统健康检测、R-CCAM 认知循环等能力。支持常驻 Python Worker 进程（零进程开销，硬件加速预热）。v8 新增 DAG 上下文管理器（SQLite 持久化 + 摘要回溯），集成到 ContextEngine 的 ingest/compact 流程。",
  "version": "8.6.0",
  "hooks": [
    {
      "event": "on_plugin_load",
      "openclaw_hook": "gateway_start",
      "degraded": false
    },
    {
      "event": "on_plugin_unload",
      "openclaw_hook": "gateway_stop",
      "degraded": false
    },
    {
      "event": "on_pre_tool_use",
      "openclaw_hook": "before_tool_call",
      "degraded": false
    },
    {
      "event": "on_post_tool_use",
      "openclaw_hook": "after_tool_call",
      "degraded": false
    },
    {
      "event": "on_pre_compaction",
      "openclaw_hook": "before_compaction",
      "degraded": true
    },
    {
      "event": "on_post_compaction",
      "openclaw_hook": "after_compaction",
      "degraded": true
    },
    {
      "event": "on_pre_agent_reply",
      "openclaw_hook": "before_agent_reply",
      "degraded": false
    },
    {
      "event": "on_post_agent_reply",
      "openclaw_hook": "agent_end",
      "degraded": false
    },
    {
      "event": "on_user_prompt_submit",
      "openclaw_hook": "before_prompt_build",
      "degraded": false
    }
  ],
