# GalaxyOS — Environment Variables (v9.0+)
# Copy to .env or export in your shell. Defaults shown.

# ── Home directory (default: ~/.galaxyos) ───────────────────────
# GALAXYOS_HOME=/root/.galaxyos

# ── Workspace (default: $GALAXYOS_HOME/workspace) ──────────────
# GALAXYOS_WORKSPACE=/root/.galaxyos/workspace

# ── Agent defaults ─────────────────────────────────────────────
GALAXYOS_AGENT_NAME=galaxy-agent
GALAXYOS_AGENT_MODEL=lfm2.5-1.2b-instruct
# GALAXYOS_AGENT_MAX_ITERATIONS=20
# GALAXYOS_AGENT_TEMPERATURE=0.7

# ── LLM providers (one of these or your own) ──────────────────
# For DeepSeek (cloud):
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# For OpenAI-compatible local (Ollama, vLLM, etc.):
# LLM_API_BASE=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5-7b

# ── LFM ONNX (local MeMo model) ────────────────────────────────
# Path to LFM2.5-1.2B-Thinking-ONNX (downloaded via install_wizard.py)
# Default probe locations:
#   1. ~/.openclaw/workspace/models/LFM2.5-1.2B-ONNX/  (legacy)
#   2. $GALAXYOS_HOME/models/LFM2.5-1.2B-ONNX/         (preferred)
#   3. /workspace/models/LFM2.5-1.2B-ONNX/             (dev)
# GALAXYOS_LFM_ONNX_DIR=/workspace/models/LFM2.5-1.2B-ONNX

# ── Legacy OpenClaw interop (only if you have an existing install) ─
# OPENCLAW_HOME=/root/.openclaw
# OPENCLAW_WORKSPACE=/root/.openclaw/workspace
# OPENCLAW_MEMORY_DIR=/root/.openclaw

# ── Sidecar ports ──────────────────────────────────────────────
# GALAXYOS_SIDECAR_HOST=127.0.0.1
# GALAXYOS_SIDECAR_PORT=5757        # zmq REP
# GALAXYOS_SIDECAR_HTTP_PORT=5758   # HTTP SSE
# GALAXYOS_SIDECAR_LOG=INFO

# ── Logging ────────────────────────────────────────────────────
# GALAXYOS_DEBUG=1
# GALAXYOS_DEBUG_PATHS=1
