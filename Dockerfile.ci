# GalaxyOS — CI 构建镜像
# 预装全部依赖，利用 Docker layer 缓存避免每次 CI 重装
#
# v9.4 变更：把 requirements-core.txt / requirements-heavy.txt 内容内联
# 进来（bash heredoc），绕开 cnb buildkit 在多文件 COPY 时的 cache key
# 撞 key 失败（"dockerfile-caches not found" + "requirements-heavy.txt
# not found"）。
#
# 用法（CNB .cnb.yml）:
#   docker:
#     build:
#       dockerfile: Dockerfile.ci

FROM python:3.12

# 系统依赖（hnswlib 编译需要 Python.h）
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        python3-dev build-essential gcc g++ && \
    rm -rf /var/lib/apt/lists/*

# === 核心依赖（轻量，CI 必装）===
# 内联内容同步自 requirements-core.txt —— 改文件时两边要同步
RUN cat > /tmp/requirements-core.txt <<'EOF'
numpy>=2.0.0
scipy>=1.10.0
pyzmq>=25.0.0
aiohttp>=3.9.0
httpx>=0.27.0
requests>=2.31.0
Pillow>=10.0.0
orjson>=3.9.0
polars>=1.0.0
duckdb>=1.0.0
jieba>=0.42.0
snownlp>=0.12.0
tiktoken>=0.5.0
uvloop>=0.19.0
psutil>=5.9.0
openai>=1.0.0
ncps>=1.0.0
tokenizers>=0.20.0
pydantic>=2.0.0
scikit-learn>=1.3.0
pytest>=9.0.0
pytest-asyncio>=0.23.0
pytest-cov>=5.0.0
EOF
RUN pip install --no-cache-dir -i https://mirrors.tencent.com/pypi/simple -r /tmp/requirements-core.txt

# === 重型依赖（CI 可选，本地开发装）===
# 内联内容同步自 requirements-heavy.txt —— 改文件时两边要同步
RUN cat > /tmp/requirements-heavy.txt <<'EOF'
mkl==2026.0.0
tbb==2023.0.0
faiss-cpu>=1.7.0
hnswlib==0.8.0
onnxruntime>=1.15.0
torch>=2.0.0
transformers>=4.44.0
pandas>=2.0.0
EOF
RUN pip install --no-cache-dir -i https://mirrors.tencent.com/pypi/simple -r /tmp/requirements-heavy.txt

# 验证关键包
RUN python -c "import numpy, scipy, sklearn, torch, pydantic, faiss, jieba, ncps, pytest, pytest_asyncio; print('deps OK')"
